# SyncWise AI — Environment Variables
# Copy this to .env.local and fill in your values

# ─── REQUIRED FOR BETA ───

# AI Prioritization (Anthropic Claude API key)
AI_API_KEY=your_anthropic_api_key

# NextAuth (required for session management)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# Admin route protection (optional — if unset, admin routes are open)
ADMIN_SECRET=your_admin_secret

# ─── FUTURE: D2L API (requires IT approval) ───

D2L_CLIENT_ID=your_d2l_client_id
D2L_CLIENT_SECRET=your_d2l_client_secret
D2L_BASE_URL=https://d2l.coloradomesa.edu
NEXT_PUBLIC_D2L_BASE_URL=https://d2l.coloradomesa.edu
NEXT_PUBLIC_D2L_CLIENT_ID=your_d2l_client_id

# ─── FUTURE: Microsoft Azure AD (requires app registration) ───
# Scopes: Calendars.ReadWrite, Mail.Read, User.Read

AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=common
