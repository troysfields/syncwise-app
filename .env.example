# SyncWise AI — Environment Variables
# Copy this to .env.local and fill in your values

# D2L Brightspace (from CMU IT after OAuth app registration)
D2L_CLIENT_ID=your_d2l_client_id
D2L_CLIENT_SECRET=your_d2l_client_secret
D2L_BASE_URL=https://coloradomesa.brightspace.com
NEXT_PUBLIC_D2L_BASE_URL=https://coloradomesa.brightspace.com
NEXT_PUBLIC_D2L_CLIENT_ID=your_d2l_client_id

# Microsoft Azure AD (from CMU IT after app registration)
# Scopes: Calendars.ReadWrite, Mail.Read, User.Read
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id

# AI Prioritization (Claude API or OpenAI)
AI_API_KEY=your_anthropic_or_openai_api_key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
